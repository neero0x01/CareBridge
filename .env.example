# Copy to .env for local docker compose / tooling overrides.
# Values below match docker-compose defaults for a one-command demo.

# Postgres
POSTGRES_DB=carebridge
POSTGRES_USER=carebridge
POSTGRES_PASSWORD=carebridge
POSTGRES_PORT=5432

# API (Spring Boot) — host ports and JDBC when running outside Compose
API_PORT=8080
DATABASE_URL=jdbc:postgresql://localhost:5432/carebridge
DATABASE_USERNAME=carebridge
DATABASE_PASSWORD=carebridge
SERVER_PORT=8080

# Web (Next.js)
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8080

# Auth (M1) — JWT HS256 secret must be ≥ 32 bytes
JWT_SECRET=carebridge-local-dev-secret-change-me-32b
# REGISTER_TENANT_ENABLED=true
# CORS_ALLOWED_ORIGINS=http://localhost:3000

# Reserved for later milestones.
# WEBHOOK_MASTER_KEY=change-me-32-byte-hex-or-base64
